# -----------------------------------------------------------------------------
# Persistence
# -----------------------------------------------------------------------------
# Live: paste Neon's pooled URL into DATABASE_URL and its direct URL into
# DATABASE_URL_UNPOOLED. Keep TLS query parameters from the Neon dashboard.
# Local demo: leave both blank and run `docker compose --profile local up --build`.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# -----------------------------------------------------------------------------
# Groq inference (backend only)
# -----------------------------------------------------------------------------
# Create one project API key at https://console.groq.com/keys.
# DEMO_MODE=true does not call Groq, so GROQ_API_KEY may remain blank locally.
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_VISION_MODEL=qwen/qwen3.6-27b
GROQ_REASONING_MODEL=openai/gpt-oss-120b
GROQ_VERIFIER_MODEL=openai/gpt-oss-120b
AI_PROVIDER=groq

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
DEMO_MODE=true
ENVIRONMENT=development
MAX_UPLOAD_MB=8
MAX_IMAGE_PIXELS=33000000
MODEL_TIMEOUT_SECONDS=45
ALLOWED_ORIGINS=http://localhost:3000
UPLOAD_DIR=/app/data/uploads

# Replace outside throwaway local development. It is used to hash anonymous
# browser ownership tokens and must not be exposed to the frontend.
ANONYMOUS_TOKEN_SALT=replace-with-at-least-32-random-characters

# This is intentionally public and is compiled into the browser application.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
